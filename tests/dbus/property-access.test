Packages: gio-2.0
D-Bus

Program: client

[DBus (name = "org.example.Test")]
interface Test : Object {
	public abstract int construct_only { get; }
	public abstract int read { get; }
	public abstract int write { set; }
	public abstract int readwrite { get; set; }

	public abstract void verify ();
}

void main () {
	// client
	Test test = Bus.get_proxy_sync (BusType.SESSION, "org.example.Test", "/org/example/test", DBusProxyFlags.DO_NOT_LOAD_PROPERTIES);

	assert (test.construct_only == 13);

	assert (test.read == 42);

	test.write = 49;
	test.verify ();

	assert (test.readwrite == 4711);
	test.readwrite = 27;
	assert (test.readwrite == 27);
}

Program: server

[DBus (name = "org.example.Test")]
class Test : Object {
	public int construct_only { get; construct; }
	public int read { get; private set; }
	public int write { private get; set; }
	public int readwrite { get; set; }

	public Test () {
		Object (construct_only : 13);
	}

	construct {
		read = 42;
		readwrite = 4711;
	}

	public void verify () {
		assert (write == 49);
	}
}

MainLoop main_loop;

void client_exit (Pid pid, int status) {
	// client finished, terminate server
	assert (status == 0);
	main_loop.quit ();
}

void main () {
	var conn = Bus.get_sync (BusType.SESSION);
	conn.register_object ("/org/example/test", new Test ());

	// try to register service in session bus
	var request_result = conn.call_sync ("org.freedesktop.DBus", "/org/freedesktop/DBus", "org.freedesktop.DBus", "RequestName",
	                                      new Variant ("(su)", "org.example.Test", 0x4), null, 0, -1);
	assert ((uint) request_result.get_child_value (0) == 1);

	// server ready, spawn client
	Pid client_pid;
	Process.spawn_async (null, { "dbus_property_access_client" }, null, SpawnFlags.DO_NOT_REAP_CHILD, null, out client_pid);
	ChildWatch.add (client_pid, client_exit);

	main_loop = new MainLoop ();
	main_loop.run ();
}
